ANTHROPIC_API_KEY=your_key_here

# --- Vertex AI (replaces GEMINI_API_KEY) ---
# Run once to authenticate: gcloud auth application-default login
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# GCS bucket for persisting Facebook session across container restarts
# Create with: gcloud storage buckets create gs://YOUR_BUCKET_NAME --project=YOUR_PROJECT_ID
GCS_SESSION_BUCKET=your-session-bucket-name